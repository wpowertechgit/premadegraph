@startdot
digraph BrandesBridge {
  graph [
    rankdir=LR,
    bgcolor="white",
    splines=true,
    nodesep=0.55,
    ranksep=0.95,
    fontname="Arial"
  ];

  node [
    shape=circle,
    style=filled,
    fixedsize=true,
    width=0.55,
    height=0.55,
    fontname="Arial",
    fontsize=11,
    color="#2f3a45",
    fillcolor="#f8f9fa",
    penwidth=1.3
  ];

  edge [
    color="#6c757d",
    arrowsize=0.45,
    penwidth=1.1
  ];

  a1 [label="A1", fillcolor="#d8f3dc"];
  a2 [label="A2", fillcolor="#d8f3dc"];
  a3 [label="A3", fillcolor="#d8f3dc"];
  a4 [label="A4", fillcolor="#d8f3dc"];
  b1 [label="B1", fillcolor="#fde2e4"];
  b2 [label="B2", fillcolor="#fde2e4"];
  b3 [label="B3", fillcolor="#fde2e4"];
  b4 [label="B4", fillcolor="#fde2e4"];
  bridge [label="X", fillcolor="#ffd166", color="#c77d00", penwidth=3.0, width=0.72, height=0.72];

  a1 -> a2;
  a1 -> a3;
  a2 -> a3;
  a2 -> a4;
  a3 -> a4;

  b1 -> b2;
  b1 -> b3;
  b2 -> b3;
  b2 -> b4;
  b3 -> b4;

  a4 -> bridge [color="#1d3557", penwidth=2.8];
  bridge -> b1 [color="#1d3557", penwidth=2.8];

  node [
    shape=box,
    style="rounded,filled",
    fixedsize=false,
    fillcolor="#eef6ff",
    color="#2f3a45",
    fontname="Arial",
    fontsize=11
  ];

  sources [label="Forráscsúcsok\npárhuzamosan"];
  shortest [label="Legrövidebb utak\nBrandes forward pass"];
  dependency [label="Függőség-visszaterjesztés\naccumulation"];
  score [label="Magas betweenness:\nX sok útvonalon híd"];

  sources -> shortest -> dependency -> score;
  bridge -> score [style=dashed, color="#c77d00"];
}
@enddot
