@startuml
title Genetic NeuroSim - Current Neural Decision Model

left to right direction
skinparam componentStyle rectangle

package "Input Layer\n11 sensors + bias" {
  [food_ratio]
  [pop_ratio]
  [territory]
  [feed_risk]
  [a_combat]
  [a_resource]
  [a_map_objective]
  [a_team]
  [nearest_enemy]
  [nearest_ally]
  [a_risk]
  [bias = 1.0]
}

package "Genome / Neural Topology" {
  [ConnectionGene\nweight, enabled,\ninnovation id] as C
  [Optional Hidden Nodes\ncreated by mutation] as H
  [tanh activation] as A
}

package "Output Layer\n7 behavioral drives" {
  [aggression]
  [resource_drive]
  [goal_drive]
  [migration_drive]
  [raid_drive]
  [isolation]
  [expansion_speed]
}

package "Rule-Based Simulation" {
  [Behavior State Machine\nSettling, Foraging, AtWar,\nAllied, Migrating, etc.] as SM
  [Action Systems\ncombat, expansion,\nalliances, migration] as ACT
}

package "Evolution" {
  [Fitness Evaluation\nevery 1000 ticks] as FIT
  [Mutation\nweights, connections,\nhidden nodes, stats] as MUT
  [Merger Crossover\nfitness-weighted inheritance] as CROSS
}

[food_ratio] --> C
[pop_ratio] --> C
[territory] --> C
[feed_risk] --> C
[a_combat] --> C
[a_resource] --> C
[a_map_objective] --> C
[a_team] --> C
[nearest_enemy] --> C
[nearest_ally] --> C
[a_risk] --> C
[bias = 1.0] --> C

C --> H
H --> A
C --> A

A --> [aggression]
A --> [resource_drive]
A --> [goal_drive]
A --> [migration_drive]
A --> [raid_drive]
A --> [isolation]
A --> [expansion_speed]

[aggression] --> SM
[resource_drive] --> SM
[goal_drive] --> SM
[migration_drive] --> SM
[raid_drive] --> SM
[isolation] --> SM
[expansion_speed] --> SM

SM --> ACT
ACT --> FIT
FIT --> MUT
MUT --> C
CROSS --> C


@enduml
