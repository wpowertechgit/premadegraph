@startuml
title Pathfinder Replay Database Diagram

skinparam backgroundColor white
skinparam shadowing false
skinparam linetype polyline
skinparam entity {
  BackgroundColor white
  BorderColor black
  FontColor black
}
skinparam note {
  BackgroundColor white
  BorderColor black
  FontColor black
}

entity "pathfinder_replays" as pathfinder_replays {
  * id : INTEGER <<PK>>
  --
  cache_key : TEXT <<UNIQUE>>
  title : TEXT
  execution_mode : TEXT
  source_player_id : TEXT
  target_player_id : TEXT
  source_label : TEXT
  target_label : TEXT
  dataset_player_count : INTEGER
  path_mode : TEXT
  weighted_mode : INTEGER
  selected_algorithm : TEXT
  comparison_rows_json : TEXT
  created_at : TEXT
}

entity "pathfinder_replay_runs" as pathfinder_replay_runs {
  * id : INTEGER <<PK>>
  --
  replay_id : INTEGER <<FK>>
  algorithm : TEXT
  runtime_ms : REAL
  nodes_visited : INTEGER
  path_length : INTEGER
  run_json : TEXT
}

pathfinder_replays ||--o{ pathfinder_replay_runs : replay_id

note right of pathfinder_replay_runs
Foreign key:
replay_id -> pathfinder_replays.id

Constraint:
UNIQUE(replay_id, algorithm)
end note

note top of pathfinder_replays
Database:
pathfinder_replays.db
end note

@enduml
