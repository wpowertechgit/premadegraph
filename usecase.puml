@startuml
left to right direction
skinparam packageStyle rectangle

actor "End User" as User
actor "Researcher/Analyst" as Researcher

rectangle "Frontend Server (React UI)" as FE {
  usecase "Submit Analysis Request" as FE_Submit
  usecase "View Match Analysis Results" as FE_ViewResults
  usecase "View Graph Page" as FE_ViewGraph
}

rectangle "Backend Server (Express API + Python jobs)" as BE {
  usecase "Analyze Matches" as BE_Analyze
  usecase "Fetch PUUID + Match Data" as BE_Fetch
  usecase "Calculate Scores + Save Data" as BE_Save
  usecase "Return Results to Frontend" as BE_Return

  usecase "Normalize Players (Python)" as BE_Normalize
  usecase "Generate Association Graph (Python)" as BE_Graph
  usecase "Run Country Pipeline (Python, optional)" as BE_Country
  usecase "Predict Cluster Countries" as BE_Predict
  usecase "Update Player Countries in DB" as BE_UpdateCountry
}

actor "Riot API" as Riot
actor "OpenRouter API" as OR

User --> FE_Submit
User --> FE_ViewResults
User --> FE_ViewGraph

FE_Submit --> BE_Analyze : HTTP/JSON
BE_Return --> FE_ViewResults : HTTP/JSON
FE_ViewGraph --> BE_Graph : request graph URL

BE_Analyze .> BE_Fetch : <<include>>
BE_Analyze .> BE_Save : <<include>>
BE_Analyze .> BE_Return : <<include>>

Researcher --> BE_Normalize
Researcher --> BE_Graph
Researcher --> BE_Country

BE_Country .> BE_Predict : <<include>>
BE_Country .> BE_UpdateCountry : <<include>>

BE_Fetch -right-> Riot
BE_Predict -right-> OR

@enduml